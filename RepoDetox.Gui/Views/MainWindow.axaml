<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:RepoDetox.Gui.Views"
        x:Class="RepoDetox.Gui.Views.MainWindow"
        Title="RepoDetox"
        Width="920"
        Height="680"
        MinWidth="640"
        MinHeight="480">
  <DockPanel Margin="12">

    <!-- Repository selector (shared across all tabs) -->
    <StackPanel DockPanel.Dock="Top" Spacing="4">
      <TextBlock Text="Repository" FontWeight="Bold" />
      <Grid ColumnDefinitions="*,Auto">
        <TextBox Grid.Column="0" Text="{Binding RepositoryPath, Mode=TwoWay}"
                 Watermark="Select a git repository folder..." />
        <Button Grid.Column="1" Content="Browse..." Command="{Binding BrowseCommand}" Margin="6,0,0,0" />
      </Grid>
      <TextBlock Text="{Binding Session.StatusLine}" Foreground="#808080" />
    </StackPanel>

    <!-- Shared output / log panel -->
    <Grid DockPanel.Dock="Bottom" RowDefinitions="Auto,160" Margin="0,10,0,0">
      <StackPanel Orientation="Horizontal" Spacing="10">
        <TextBlock Text="Output" FontWeight="Bold" VerticalAlignment="Center" />
        <ProgressBar IsIndeterminate="{Binding Coordinator.IsBusy}" Width="140" VerticalAlignment="Center" />
        <Button Content="Cancel" Command="{Binding Coordinator.CancelCommand}" IsEnabled="{Binding Coordinator.IsBusy}" />
        <Button Content="Clear" Command="{Binding Coordinator.ClearLogCommand}" />
      </StackPanel>
      <Border Grid.Row="1" BorderBrush="#80808080" BorderThickness="1" Margin="0,4,0,0">
        <ScrollViewer>
          <ItemsControl ItemsSource="{Binding Coordinator.Log}" Margin="4">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding}" FontFamily="Consolas,Menlo,monospace" FontSize="12" TextWrapping="Wrap" />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Border>
    </Grid>

    <!-- Feature tabs -->
    <TabControl Margin="0,10,0,0">
      <TabItem Header="Analyze">
        <views:AnalyzeView DataContext="{Binding Analyze}" />
      </TabItem>
      <TabItem Header="Vacuum">
        <views:VacuumView DataContext="{Binding Vacuum}" />
      </TabItem>
      <TabItem Header="Anonymise">
        <views:AnonymiseView DataContext="{Binding Anonymise}" />
      </TabItem>
      <TabItem Header="Flatten">
        <views:FlattenView DataContext="{Binding Flatten}" />
      </TabItem>
    </TabControl>

  </DockPanel>
</Window>
