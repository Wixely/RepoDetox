{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/RepoDetox.slnx"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "run:gui",
      "type": "process",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/RepoDetox.Gui/RepoDetox.Gui.csproj"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "run:list",
      "type": "process",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/RepoDetox/RepoDetox.csproj",
        "--",
        "list",
        "--repo",
        "${workspaceFolder}"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "run:preview",
      "type": "process",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/RepoDetox/RepoDetox.csproj",
        "--",
        "preview",
        "--repo",
        "${workspaceFolder}",
        "--port",
        "5078"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "run:anonymise",
      "type": "process",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/RepoDetox/RepoDetox.csproj",
        "--",
        "anonymise",
        "--repo",
        "${workspaceFolder}"
      ],
      "problemMatcher": "$msCompile"
    }
  ]
}
